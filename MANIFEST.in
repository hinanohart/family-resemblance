include LICENSE
include README.md
include CHANGELOG.md
include CONTRIBUTING.md
include pyproject.toml
include MANIFEST.in

recursive-include docs *.md
recursive-include examples *.py
recursive-include tests *.py
recursive-include src/family_resemblance *.py

# data/ holds a 22000-line Tractatus PD corpus that runtime never touches;
# keep it out of the sdist to avoid bloating PyPI downloads, but ship
# PROVENANCE.md so README links resolve on PyPI.
prune data
include data/PROVENANCE.md
prune build
prune dist
prune .venv
prune experiments
prune .git
prune .pytest_cache
prune .ruff_cache
prune .mypy_cache

global-exclude __pycache__
global-exclude *.py[cod]
global-exclude .DS_Store
global-exclude *.egg-info
